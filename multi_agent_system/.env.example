# PRAXIS-SENATE - Environment Configuration
# Copy this file to .env and fill in your API keys

# ===========================================
# LLM Provider API Keys
# Configure at least ONE provider for the system to work
# ===========================================

# OpenAI (GPT-4, GPT-3.5, etc.)
OPENAI_API_KEY=your_openai_api_key_here

# Anthropic (Claude 3, Opus, Sonnet, etc.)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Google AI (Gemini Pro, etc.)
GOOGLE_API_KEY=your_google_api_key_here

# OpenRouter (Multi-model aggregator - supports Claude, GPT, Llama, etc.)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# MiniMax (Chinese LLM provider)
MINIMAX_API_KEY=your_minimax_api_key_here

# ===========================================
# System Configuration (optional)
# ===========================================

# Default LLM provider (openai, anthropic, google, openrouter, minimax)
DEFAULT_LLM_PROVIDER=openai

# Logging level (DEBUG, INFO, WARNING, ERROR)
# LOG_LEVEL=INFO

# Maximum concurrent workers
# MAX_WORKERS=5

# Docker network name (for docker-compose)
# DOCKER_NETWORK=praxix_senate
