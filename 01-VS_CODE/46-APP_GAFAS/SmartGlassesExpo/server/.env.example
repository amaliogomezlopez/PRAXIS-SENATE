# ⚠️ Copy this to .env and fill in your values. NEVER commit .env!
MINIMAX_API_KEY=your_minimax_api_key_here
OPENCODE_API_KEY=your_opencode_api_key_here
OPENCODE_BASE_URL=https://opencode.ai/zen/go/v1
HERMES_API_KEY=your_hermes_api_server_key_here
HERMES_API_BASE_URL=http://127.0.0.1:8642/v1
HERMES_MODEL=deepseek-v4-flash
HERMES_TIMEOUT_SECONDS=120
HERMES_SWITCH_MODELS_ENABLED=false
HERMES_OPENCODE_CONTEXT_LENGTH=65536
OPENCODE_GO_MODELS=kimi-k2.6,kimi-k2.5,deepseek-v4-pro,deepseek-v4-flash,glm-5.1,glm-5,mimo-v2.5-pro,mimo-v2.5,mimo-v2-pro,mimo-v2-omni,minimax-m2.7,minimax-m2.5,qwen3.6-plus,qwen3.5-plus
# ── xAI (Grok) Realtime Voice ─────────────────────────────
# Master key stays here (server-side only). The app receives a short-lived
# ephemeral token via POST /api/v1/xai/realtime/session — never this key.
XAI_API_KEY=your_xai_api_key_here
XAI_REALTIME_MODEL=grok-voice-latest
XAI_TOKEN_TTL_SECONDS=300

MAX_REQUEST_BYTES=262144
KOKORO_ENABLED=false
APP_TOKEN=legacy_admin_token_only_if_needed
DEVICE_AUTH_ENABLED=true
ALLOW_LEGACY_APP_TOKEN=false
AUTH_DB_PATH=/home/amalio/smartglasses-proxy/auth.sqlite3
AUTH_TOKEN_PEPPER=generate_a_long_random_pepper_here
DEVICE_TOKEN_TTL_DAYS=365
PAIRING_CODE_TTL_SECONDS=900
PORT=5050
RATE_LIMIT=30
CORS_ORIGINS=*
