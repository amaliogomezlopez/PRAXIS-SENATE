# =============================================================
# SmartGlasses AI — Variables de entorno (EJEMPLO)
# =============================================================
# Copia este archivo como .env y rellena tus claves reales.
# NUNCA subas .env a git — solo este .env.example
# =============================================================

# --- Claves privadas del proxy local/servidor ---
# No uses EXPO_PUBLIC_* para claves: esas variables pueden acabar en el bundle movil.
# La app de App Store debe llamar al proxy; las claves reales viven en server/.env o en el llavero
# si se guardan manualmente desde Ajustes para pruebas locales.
MINIMAX_API_KEY=tu_api_key_de_minimax_aqui
MINIMAX_GROUP_ID=tu_group_id_aqui
OPENAI_API_KEY=sk-tu_api_key_openai_aqui
ANTHROPIC_API_KEY=sk-ant-tu_api_key_aqui
GOOGLE_API_KEY=AItu_api_key_aqui
ELEVENLABS_API_KEY=xi-tu_api_key_aqui
OPENCODE_API_KEY=tu_api_key_opencode_go_aqui
NVIDIA_API_KEY=nvapi-tu_api_key_nvidia_aqui
HERMES_API_KEY=clave_bearer_del_api_server_hermes
HERMES_API_BASE_URL=http://127.0.0.1:8642/v1
HERMES_MODEL=deepseek-v4-flash
HERMES_TIMEOUT_SECONDS=120
HERMES_SWITCH_MODELS_ENABLED=false
HERMES_OPENCODE_CONTEXT_LENGTH=65536
OPENCODE_GO_MODELS=kimi-k2.6,kimi-k2.5,deepseek-v4-pro,deepseek-v4-flash,glm-5.1,glm-5,mimo-v2.5-pro,mimo-v2.5,mimo-v2-pro,mimo-v2-omni,minimax-m2.7,minimax-m2.5,qwen3.6-plus,qwen3.5-plus
MAX_REQUEST_BYTES=262144

# --- xAI (Grok) Realtime Voice (opcional, modo premium) ---
# La key maestra NO va aquí (aquí iría al bundle). Vive en server/.env como XAI_API_KEY.
# El móvil solo recibe un token efímero del proxy (POST /api/v1/xai/realtime/session).
# No se necesita ninguna variable EXPO_PUBLIC_* para Grok.

# --- Proxy de la app ---
# En web local puedes usar http://localhost:5050 para evitar CORS del proveedor.
EXPO_PUBLIC_PROXY_BASE_URL=https://sibelion.ddns.net:8443
# Normalmente vacío: la app usa un token por dispositivo guardado en SecureStore.
EXPO_PUBLIC_PROXY_APP_TOKEN=

# --- Endpoints publicos no secretos ---
EXPO_PUBLIC_OPENCODE_BASE_URL=https://opencode.ai/zen/go/v1
EXPO_PUBLIC_NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
